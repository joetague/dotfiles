[user]
	# Name used in commit messages.
	name = Joe Tague
	# Email used in commit messages.
	email = joetague@users.noreply.github.com

[github]
	# GitHub username for command-line tools.
	user = joetague

[push]
	# Push to the set upstream branch being tracked by default.
	default = simple
	# git 2.37+: auto-create the upstream branch on first push of a new
	# branch, so `git push` works without --set-upstream and `gh pr create`
	# picks it up.
	autoSetupRemote = true

[pull]
	# Default to rebasing on pulls
	rebase = true

[fetch]
	# Always prune when fetching (and pulling).
	prune = true
	# Refresh the commit-graph on fetch → faster log/merge-base/blame on
	# large histories. Negligible cost on small repos.
	writeCommitGraph = true
	# Faster negotiation when fetching against repos with many refs.
	negotiationAlgorithm = skipping

[rebase]
	# Run `git stash` if needed before a `git rebase`
	autoStash = true
	# Auto-add `--autosquash` to `git rebase`
	autoSquash = true
	# git 2.38+: update local branches pointing into the rebased range
	# (stacked branches / stacked PRs).
	updateRefs = true

[rerere]
	# Record conflict resolutions and replay them automatically.
	enabled = true

[merge]
	# git 2.35+: conflict markers that also show the common ancestor.
	conflictStyle = zdiff3

[apply]
	# Cleanup whitespace by default when apply patches.
	whitespace = fix

[core]
	editor = emacsclient --no-wait --create-frame
	excludesfile = ~/.config/git/ignore
	fsmonitor = true
	untrackedcache = true

[mergetool]
	# Don't prompt before opening the merge tool.
	prompt = false
	# Don't keep backups of the merge tool inputs.
	keepBackup = false
	# Don't keep the merge tool temporary input/output files.
	keepTemporaries = false

[init]
	defaultBranch = main

[checkout]
	# Parallel working-tree updates on checkout/clone (0 = all cores).
	# No effect on small repos; speeds large monorepo checkouts.
	workers = 0

[index]
	# Path-compressed index → smaller, faster index reads on large worktrees.
	version = 4
	# git 2.40+: skip the trailing index checksum on write → faster index
	# writes on large worktrees. Index is readable by git >= 2.40 only
	# (all my machines), and by tools that shell out to git (e.g. Magit).
	skipHash = true

[diff]
	# Histogram produces cleaner diffs than the default Myers algorithm.
	algorithm = histogram
	# Color moved lines differently from added/removed lines.
	colorMoved = zebra
	# Also detect moves whose only change is indentation.
	colorMovedWS = allow-indentation-change

[commit]
	# Show the full diff in the commit message editor for review.
	verbose = true

[branch]
	# List branches most-recently-committed first.
	sort = -committerdate

[tag]
	# Sort tags as versions (v1.10 after v1.9).
	sort = version:refname

[column]
	# Compact, multi-column output for status/branch/tag listings.
	ui = auto

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
